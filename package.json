{
  "name": "@miaos/catsay",
  "version": "0.1.2",
  "description": "catsay is a cat say something...",
  "main": "dist/catsay.cjs",
  "module": "dist/catsay.es.js",
  "types": "dist/index.d.ts",
  "browser": "dist/catsay.umd.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/catsay.cjs",
      "import": "./dist/catsay.es.js",
      "default": "./dist/catsay.es.js"
    }
  },
  "files": [
    "dist",
    "catsay.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs && tsc -p tsconfig.json --emitDeclarationOnly && node ./scripts/ensure-executable.mjs catsay.js dist/cli.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "node --test \"test/**/*.test.cjs\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pomelo-chuan/catsay.git"
  },
  "keywords": [
    "catsay",
    "catthink",
    "cowsay",
    "talking",
    "ASCII",
    "art"
  ],
  "author": "pomelo-chuan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pomelo-chuan/catsay/issues"
  },
  "bin": {
    "catsay": "./dist/cli.cjs",
    "catthink": "./dist/cli.cjs"
  },
  "homepage": "https://github.com/pomelo-chuan/catsay#readme",
  "dependencies": {
    "string-width": "^5.1.2",
    "yargs": "^17.4.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.6.1",
    "@types/yargs": "^17.0.35",
    "rollup": "^4.60.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
